# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Wasender
WASENDER_API_KEY=your_wasender_api_key
WASENDER_API_URL=https://api.wasender.com/v1
WASENDER_WEBHOOK_SECRET=your_webhook_secret
TEAM_CHAT_ID=your_team_chat_id@c.us

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Redis
REDIS_URL=redis://localhost:6379

# ChromaDB
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=monjez_kb

# Knowledge Base
VAULT_PATH=./knowledge/obsidian

# LLM
LLM_TIMEOUT_MS=8000
LLM_RETRY_TIMEOUT_MS=4000

# Features
ENABLE_COMPRESSION=true
ENABLE_ESCALATION=true
ENABLE_METRICS=true
